# --- MAX (обязательно) ---
MAX_ACCESS_TOKEN=

# Кто может менять настройки в ЛС бота (id через запятую). Пусто = любой.
BOT_ADMIN_USER_IDS=

# Однократный импорт при первом создании БД (потом — кнопки «Настройки бота»)
MONITORED_CHAT_IDS=
MANAGER_CHAT_ID=
DUTY_USER_IDS=

# --- LLM: yandex | yandexgpt | gigachat ---
LLM_PROVIDER=yandex

YANDEX_IAM_TOKEN=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL_URI=
YANDEX_TEMPERATURE=0.15
YANDEX_MAX_TOKENS=1800

GIGACHAT_CREDENTIALS=

# --- Поведение ---
# Алиасы: SUPERVISOR_DB_PATH, SUPERVISOR_CONTEXT_MESSAGES, SUPERVISOR_ANALYZE_DEBOUNCE_SECONDS
SQLITE_PATH=./data/supervisor.sqlite
CONTEXT_WINDOW_MESSAGES=40
ANALYSIS_DEBOUNCE_SECONDS=0
LONG_POLL_TIMEOUT=45
LONG_POLL_LIMIT=100

LOG_LEVEL=INFO
